# Google Ads API
GOOGLE_ADS_DEVELOPER_TOKEN=YOUR_DEVELOPER_TOKEN
GOOGLE_ADS_CLIENT_ID=YOUR_OAUTH_CLIENT_ID.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=YOUR_OAUTH_CLIENT_SECRET
GOOGLE_ADS_REFRESH_TOKEN=YOUR_REFRESH_TOKEN
GOOGLE_ADS_LOGIN_CUSTOMER_ID=YOUR_MCC_ID
GOOGLE_ADS_CUSTOMER_ID=YOUR_CUSTOMER_ID

# GA4
GA4_PROPERTY_ID=YOUR_GA4_PROPERTY_ID

# Optional: Application Default Credentials or service account JSON for read-only tools.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/adc.json

# Optional: base URL for generated ads. Use your real landing page domain locally.
SITE_ROOT=https://www.acme-corp.example

